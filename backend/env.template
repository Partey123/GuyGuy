# GuyGuy Backend Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080
APP_ENV=development

# Supabase Configuration (REQUIRED)
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Database Configuration
# Use the connection string from Supabase Settings > Database
DATABASE_URL=postgresql://postgres:[password]@db.your-project-id.supabase.co:5432/postgres

# Paystack Configuration (for payments)
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# Email Service (Resend)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@guyguy.com.gh

# SMS Service (Arkesel)
ARKESEL_API_KEY=your-arkesel-api-key
ARKESEL_SENDER_ID=GuyGuy

# Firebase Configuration (for push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Google Maps API Key (for location services)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Error Tracking (Sentry - optional)
SENTRY_DSN=your-sentry-dsn

# Development Notes:
# 1. For local development, set APP_ENV=development
# 2. For production, set APP_ENV=production and ensure all secrets are secure
# 3. Never commit the actual .env file to version control
# 4. Use strong, unique secrets for all services
